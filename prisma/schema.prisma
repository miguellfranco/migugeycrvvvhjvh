generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/leadzap/nextjs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  name                 String?
  passwordHash         String?
  plan                 String    @default("free") // mensal | vitalicio | free
  planStatus           String    @default("trial") // active | inactive | trial
  stripeCustomerId     String?
  stripeSubscriptionId String?
  referralCode         String    @unique
  referredBy           String?
  leadsUsedToday       Int       @default(0)
  leadsResetDate       DateTime  @default(now())
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  leads                Lead[]
  messages             Message[]
  sales                Sale[]
  affiliatesAsReferrer Affiliate[] @relation("Referrer")
  affiliatesAsReferred Affiliate[] @relation("Referred")

  @@index([referralCode])
  @@index([email])
}

model Lead {
  id              String    @id @default(cuid())
  userId          String
  businessName    String
  phone           String?
  city            String?
  niche           String?
  rating          Float?
  reviewCount     Int?
  hasWebsite      Boolean   @default(false)
  yearsWithoutSite Int?
  score           Int       @default(0) // 0-10
  tier            String    @default("cold") // hot | warm | cold
  status          String    @default("novo") // novo | mensagem_gerada | enviado | respondeu | venda_fechada | ignorado
  apifyPlaceId    String?
  createdAt       DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages        Message[]
  sales           Sale[]

  @@index([userId])
  @@index([userId, createdAt])
}

model Message {
  id              String    @id @default(cuid())
  userId          String
  leadId          String
  messageText     String    @db.Text
  generatedAt     DateTime  @default(now())
  sentAt          DateTime?
  whatsappOpenedAt DateTime?

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead            Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([leadId])
}

model Sale {
  id          String    @id @default(cuid())
  userId      String
  leadId      String?
  niche       String?
  city        String?
  saleValue   Float?
  description String?   @db.Text
  isPublic    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead        Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
}

model Affiliate {
  id                 String   @id @default(cuid())
  referrerId         String
  referredUserId     String
  planType           String?  // mensal | vitalicio
  firstCommission    Float    @default(0)
  recurringCommission Float   @default(0)
  status             String   @default("active") // active | cancelled
  totalEarned        Float    @default(0)
  createdAt          DateTime @default(now())

  referrer           User     @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referred           User     @relation("Referred", fields: [referredUserId], references: [id], onDelete: Cascade)
  commissions        Commission[]

  @@index([referrerId])
}

model Commission {
  id              String   @id @default(cuid())
  affiliateId     String
  amount          Float
  type            String   // first | recurring
  stripePaymentId String?
  status          String   @default("pending") // pending | paid
  createdAt       DateTime @default(now())

  affiliate       Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@index([affiliateId])
}
